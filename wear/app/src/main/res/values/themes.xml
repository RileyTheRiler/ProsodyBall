<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Fullscreen, no action bar — the WebView owns the whole round screen. -->
    <style name="Theme.VoxArcadeWear" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <!-- Worn under a collar/pocket while masked; an accidental swipe shouldn't close it. -->
        <item name="android:windowSwipeToDismiss">false</item>
    </style>
</resources>
